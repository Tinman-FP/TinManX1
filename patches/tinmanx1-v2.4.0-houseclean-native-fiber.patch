+        help="Optional path to the full TinManX1 build_strength_visualization.py tool.",
+    )
+    parser.add_argument(
+        "--force-fallback",
+        action="store_true",
+        help="Use the compact Orca fallback even if the full TinManX1 builder is available.",
+    )
+    return parser.parse_args()
