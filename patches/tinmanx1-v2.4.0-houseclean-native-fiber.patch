+def lane_kind(role: str) -> str:
+    normalized = role.strip().lower()
+    if normalized == "fiber_drive":
+        return "continuous_fiber"
+    if "support" in normalized:
+        return "support_material"
+    if "composite" in normalized:
+        return "composite_polymer"
+    return "polymer"
