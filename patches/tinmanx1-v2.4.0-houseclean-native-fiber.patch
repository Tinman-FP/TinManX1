+def splitGCodeIntoLayers(gcode:list)->list:
+    gcode_list = []
+    buff=[]
+    for linenumber,line in enumerate(gcode):
+        if ";LAYER_CHANGE" in line:
+            gcode_list.append(buff)
+            buff=[]
+            buff.append(line)
+        else:
+            buff.append(line)
+    gcode_list.append(buff)  #catch last layer
+    print("last read linenumber:",linenumber)
+    return gcode_list
+
+def getPtfromCmd(line:str)->Point | None:
+    x=None
+    y=None
+    line=line.split(";")[0]
+    cmds=line.split(" ")
+    for c in cmds:
+        if "X" in c:
+            x=float(c[1:])
+        elif "Y" in c:
+            y=float(c[1:])
+    if (x is not None) and (y is not None):
+        p=Point(x,y)
+    else:
+        p=None
+    return p
+
+def makePolygonFromGCode(lines:list)->Polygon:
+    pts=[]
+    for line in lines:
+        if ";WIPE" in line:
+            break
+        if "G1" in line:
+            p=getPtfromCmd(line)
+            if p:
+                pts.append(p)
+    if len(pts)>2:
+        return Polygon(pts)
+    else:
+        #print("invalid poly: not enough pts")
+        return None
