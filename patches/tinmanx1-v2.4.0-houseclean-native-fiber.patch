+def mixed_lane_material_label(lane: dict[str, Any]) -> str:
+    fiber_material = nested(lane.get("fiber_material"))
+    for value in (
+        lane.get("filament_settings_id"),
+        lane.get("material_type"),
+        fiber_material.get("name"),
+        lane.get("role"),
