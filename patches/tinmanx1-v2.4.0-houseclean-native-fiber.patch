+def load_case_direction_label(x: float, y: float, z: float) -> str:
+    labels = []
+    for axis, value in (("X", x), ("Y", y), ("Z", z)):
+        if abs(value) <= 1.0e-9:
+            continue
+        labels.append(f"{'+' if value > 0 else '-'}{axis}")
+    return " ".join(labels) if labels else "0"
